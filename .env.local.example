# GHMD Sales Platform — local environment example
# Copy to .env.local and fill in. NEVER commit real secrets.
# Production secrets live in Netlify env vars + Supabase Edge Function secrets.

# Supabase — ghmd-sales-platform project (cprltmwwldbxcsunsafl) ONLY. Never the NIP.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Preferred: modern Supabase secret key (sb_secret_... — not a JWT). Server-only.
SUPABASE_SECRET_KEY=

# Deprecated fallback: legacy service_role JWT. Read ONLY when the preferred key
# above is absent or blank; removed once rotation completes (decision #199).
# Precedence is owned by src/lib/supabase/secret-key.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Census Bureau ACS API key (server-only — never exposed to the client).
# Already live in Netlify env vars; set locally to exercise /api/census/territory.
CENSUS_API_KEY=

# Mapbox (client) — restricted to the proposals subdomain in production.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Mapbox (server) — v3 drive-time sizing engine. Distinct from the client token
# above: the client token is referer/URL-restricted and cannot authenticate
# server-side batch isochrone calls. Server-only, never exposed to the client.
# Provisioned by Trace (Hard Rule 6) — leave blank locally unless exercising the
# v3 sizing route.
MAPBOX_SERVER_TOKEN=
